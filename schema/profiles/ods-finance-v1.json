{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ODS-Foundation/ods-specification/schema/profiles/ods-finance-v1.json",
  "title": "ODS Finance Profile v1",
  "description": "Profile schema for ODS-Finance/v1. Applied as a second validation pass after core schema (ods_record_v2.json). Defines finance-domain-specific fields migrated from ODS Core v1.1.0.",
  "if": {
    "properties": { "record_type": { "const": "DECISION" } }
  },
  "then": {
    "properties": {
      "context": {
        "type": "object",
        "properties": {
          "regime_state": {
            "type": "string",
            "enum": ["NORMAL", "TRANSITION", "CRISIS", "RECOVERY"],
            "description": "Detected market regime at decision time"
          },
          "regime_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence in regime classification"
          },
          "volatility_state": {
            "type": "string",
            "enum": ["LOW", "NORMAL", "ELEVATED", "EXTREME"],
            "description": "Volatility environment at decision time"
          },
          "macro_state_vector": {
            "type": "array",
            "items": { "type": "number" },
            "description": "Normalized macro-economic indicators at decision time"
          }
        }
      },
      "action": {
        "type": "object",
        "required": ["action_type"],
        "properties": {
          "action_type": {
            "type": "string",
            "enum": ["BUY", "SELL", "HOLD", "REDUCE", "INCREASE", "ABSTAIN"],
            "description": "ODS-Finance/v1 action vocabulary. Records claiming this profile MUST use one of these values."
          },
          "risk_posture": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Risk appetite at decision time. 0.0 = minimum risk, 1.0 = maximum risk."
          },
          "capital_at_risk_bps": {
            "type": "number",
            "description": "Capital at risk expressed in basis points"
          }
        }
      },
      "governance": {
        "type": "object",
        "properties": {
          "compliance": {
            "type": "object",
            "properties": {
              "risk_limit_checks": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Finance-domain pre-decision gate check results (e.g., 'PASSED', 'RISK_LIMIT_EXCEEDED')"
              }
            }
          }
        }
      }
    }
  },
  "else": {
    "properties": {
      "governance": {
        "type": "object",
        "properties": {
          "compliance": {
            "type": "object",
            "properties": {
              "risk_limit_checks": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Finance-domain compliance check results on OUTCOME records"
              }
            }
          }
        }
      }
    }
  }
}
