{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ODS-Foundation/ods-specification/schema/ods_record_v2.json",
  "title": "ODS v2.x Core Record Schema",
  "description": "JSON Schema for validating ODS v2.0.0 and v2.1.0 core records (DECISION, OUTCOME, and CHECKPOINT types). Domain-specific fields are validated in a second pass by profile schemas in schema/profiles/.",
  "type": "object",
  "required": ["_schema_version", "record_type", "record_id", "timestamp_utc"],
  "properties": {
    "_schema_version": {
      "type": "string",
      "enum": ["2.0.0", "2.1.0"],
      "description": "ODS schema version"
    },
    "record_type": {
      "type": "string",
      "enum": ["DECISION", "OUTCOME", "CHECKPOINT"],
      "description": "Discriminator determining which fields are required and valid"
    },
    "record_id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique UUID v4 identifier for this record"
    },
    "sequence_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Store-assigned monotonically increasing Merkle log position. Present in v2.1.0+ stored representations from Standard-and-above stores. Clients MUST NOT submit this field; the store assigns it at write time."
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime in UTC with microsecond precision"
    },
    "parent_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the parent record. Required for OUTCOME. Must reference an existing record_id in the store at write time."
    },
    "profile": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9-]*/v[0-9]+$",
      "description": "Domain profile namespace and major version (e.g., 'ODS-Finance/v1'). Required on DECISION when action section is present. Optional on OUTCOME; if present, must match parent DECISION's profile."
    }
  },
  "if": {
    "properties": { "record_type": { "const": "DECISION" } }
  },
  "then": {
    "allOf": [
      {
        "required": ["identity", "cognition", "governance"],
        "not": {
          "required": ["outcomes"]
        },
        "properties": {
          "identity": {
            "type": "object",
            "required": ["model_version", "policy_hash"],
            "properties": {
              "model_version": {
                "type": "string",
                "pattern": "^v?\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$",
                "description": "Semantic version of the decision model or process"
              },
              "policy_hash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$",
                "description": "SHA-256(JCS(policy_object)) per RFC 8785. 64-character lowercase hexadecimal."
              }
            },
            "additionalProperties": false
          },
          "context": {
            "type": "object",
            "description": "Extensible context container. Core imposes no required properties. Profiles define domain-specific context fields."
          },
          "action": {
            "type": "object",
            "required": ["action_type"],
            "properties": {
              "action_type": {
                "type": "string",
                "description": "Domain-specific action category. ODS does not constrain this vocabulary."
              },
              "action_size": {
                "type": "number",
                "description": "Magnitude of action in domain-specific units"
              },
              "expected_value": {
                "type": "number",
                "description": "Expected outcome of the decision in domain-specific units"
              }
            },
            "description": "Action layer. Present on operational DECISION records; absent on governance-only records. Profiles extend this object with domain-specific fields."
          },
          "cognition": {
            "type": "object",
            "required": ["confidence", "rationale"],
            "properties": {
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "uncertainty_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "decision_latency_ms": {
                "type": "integer",
                "minimum": 0
              },
              "rationale": {
                "type": "string",
                "minLength": 10,
                "maxLength": 2000
              }
            }
          },
          "counterfactuals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["alternative_action", "expected_outcome"],
              "properties": {
                "alternative_action": { "type": "string" },
                "expected_outcome": { "type": "number" },
                "regret": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "governance": {
            "type": "object",
            "required": ["audit_trail"],
            "properties": {
              "audit_trail": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["timestamp_utc", "event", "actor"],
                  "properties": {
                    "timestamp_utc": { "type": "string", "format": "date-time" },
                    "event": {
                      "type": "string",
                      "enum": ["DECISION_CREATED", "VERIFIED", "AUDITED"]
                    },
                    "actor": { "type": "string" },
                    "metadata": { "type": "object" }
                  },
                  "additionalProperties": false
                }
              },
              "explainability": { "type": "object" },
              "compliance": {
                "type": "object",
                "properties": {
                  "policy_violations": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Core field. Documents policy breaches. Universal across all domains."
                  },
                  "approvals": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Core field. Documents authorization grants. Universal across all domains."
                  }
                },
                "description": "Core compliance fields. Profiles extend this object with domain-specific compliance fields (e.g., risk_limit_checks in ODS-Finance/v1)."
              }
            },
            "description": "Governance layer. Profiles may extend this object with domain-specific governance fields."
          }
        }
      },
      {
        "description": "E4 rule: profile is required when action section is present.",
        "if": { "required": ["action"] },
        "then": { "required": ["profile"] }
      }
    ]
  },
  "else": {
    "if": {
      "properties": { "record_type": { "const": "OUTCOME" } }
    },
    "then": {
      "required": ["parent_id", "outcome_status", "outcomes", "governance"],
      "properties": {
        "outcome_status": {
          "type": "string",
          "enum": ["PARTIAL", "FINAL"],
          "description": "PARTIAL: intermediate measurement. FINAL: closes the outcome cycle. Only one FINAL permitted per parent_id chain; enforced at write time by the store."
        },
        "outcomes": {
          "type": "object",
          "required": ["actual_result", "realized_at", "delta_from_expected"],
          "properties": {
            "actual_result": { "type": "number" },
            "realized_at": { "type": "string", "format": "date-time" },
            "delta_from_expected": { "type": "number" },
            "outcome_quality": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        },
        "governance": {
          "type": "object",
          "required": ["audit_trail"],
          "properties": {
            "audit_trail": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["timestamp_utc", "event", "actor"],
                "properties": {
                  "timestamp_utc": { "type": "string", "format": "date-time" },
                  "event": {
                    "type": "string",
                    "enum": ["OUTCOME_LOGGED", "VERIFIED", "AUDITED"]
                  },
                  "actor": { "type": "string" },
                  "metadata": { "type": "object" }
                },
                "additionalProperties": false
              }
            },
            "compliance": {
              "type": "object",
              "properties": {
                "policy_violations": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "approvals": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "description": "Core compliance fields. Profiles extend this object with domain-specific compliance fields."
            }
          }
        }
      }
    },
    "else": {
      "description": "CHECKPOINT record type (v2.1.0+)",
      "required": ["identity", "checkpoint"],
      "properties": {
        "identity": {
          "type": "object",
          "required": ["model_version", "policy_hash"],
          "properties": {
            "model_version": {
              "type": "string",
              "pattern": "^v?\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$"
            },
            "policy_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "additionalProperties": false
        },
        "checkpoint": {
          "type": "object",
          "required": ["tree_size", "tree_root", "covers_through_sequence_number", "ordering"],
          "properties": {
            "tree_size": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of records included as leaves in this Merkle tree"
            },
            "tree_root": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$",
              "description": "64-character lowercase hex SHA-256 Merkle root"
            },
            "covers_through_sequence_number": {
              "type": "integer",
              "minimum": 0,
              "description": "sequence_number of the last record included in this tree"
            },
            "ordering": {
              "type": "string",
              "const": "sequence_number ASC",
              "description": "Canonical ordering used for Merkle tree construction"
            }
          },
          "additionalProperties": false
        }
      }
    }
  }
}
