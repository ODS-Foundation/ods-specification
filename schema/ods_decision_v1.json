{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ODS-Foundation/ods-specification/schema/ods_decision_v1.json",
  "title": "ODS v1.0 Decision Schema",
  "description": "JSON Schema for validating ODS v1.0 compliant decision records",
  "type": "object",
  "required": ["_schema_version", "identity", "action", "cognition", "governance"],
  "properties": {
    "_schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "ODS schema version"
    },
    "identity": {
      "type": "object",
      "required": ["decision_id", "timestamp_utc", "model_version", "policy_hash"],
      "properties": {
        "decision_id": {
          "type": "string",
          "format": "uuid",
          "description": "Globally unique UUID v4 identifier"
        },
        "timestamp_utc": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 datetime in UTC with microsecond precision"
        },
        "model_version": {
          "type": "string",
          "pattern": "^v?\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$",
          "description": "Semantic version of decision model"
        },
        "policy_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hash of decision policy"
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "regime_state": {
          "type": "string",
          "enum": ["NORMAL", "TRANSITION", "CRISIS", "RECOVERY"]
        },
        "regime_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "volatility_state": {
          "type": "string",
          "enum": ["LOW", "NORMAL", "ELEVATED", "EXTREME"]
        },
        "macro_state_vector": {
          "type": "array",
          "items": {"type": "number"}
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["action_type"],
      "properties": {
        "action_type": {
          "type": "string",
          "description": "Type of action taken (domain-specific)"
        },
        "action_size": {
          "type": "number",
          "description": "Magnitude of action (domain-specific units)"
        },
        "risk_posture": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "capital_at_risk_bps": {
          "type": "integer",
          "minimum": 0
        },
        "expected_value": {
          "type": "number"
        }
      }
    },
    "cognition": {
      "type": "object",
      "required": ["confidence", "rationale"],
      "properties": {
        "expected_value": {
          "type": "number"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "uncertainty_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "decision_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "rationale": {
          "type": "string",
          "minLength": 10,
          "maxLength": 2000
        }
      }
    },
    "outcomes": {
      "type": "object",
      "properties": {
        "actual_result": {
          "type": "number"
        },
        "realized_at": {
          "type": "string",
          "format": "date-time"
        },
        "delta_from_expected": {
          "type": "number"
        },
        "outcome_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "counterfactuals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["alternative_action", "expected_outcome"],
        "properties": {
          "alternative_action": {
            "type": "string"
          },
          "expected_outcome": {
            "type": "number"
          },
          "regret": {
            "type": "number"
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "required": ["audit_trail"],
      "properties": {
        "audit_trail": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["timestamp_utc", "event", "actor"],
            "properties": {
              "timestamp_utc": {
                "type": "string",
                "format": "date-time"
              },
              "event": {
                "type": "string",
                "enum": ["DECISION_CREATED", "OUTCOME_LOGGED", "VERIFIED", "AUDITED"]
              },
              "actor": {
                "type": "string"
              },
              "metadata": {
                "type": "object"
              }
            }
          }
        },
        "explainability": {
          "type": "object"
        },
        "compliance": {
          "type": "object",
          "properties": {
            "risk_limit_checks": {
              "type": "array",
              "items": {"type": "string"}
            },
            "policy_violations": {
              "type": "array",
              "items": {"type": "string"}
            },
            "approvals": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
